# PostgreSQL (Neon / Supabase)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Resend — e-mails de confirmação
RESEND_API_KEY="re_xxxxxxxx"
RESEND_FROM="Nexa App <onboarding@resend.dev>"
CORPORATE_EMAIL="equipe@seudominio.com"

# Admin — mínimo 32 caracteres (timing-safe auth)
ADMIN_SECRET="gere_um_token_aleatorio_com_pelo_menos_32_caracteres"

# CORS / domínio de produção
DOMAIN="https://seu-dominio.vercel.app"
FRONTEND_URL="https://seu-dominio.vercel.app"

# LGPD — versão do termo de consentimento
CONSENT_VERSION="1.0"

# Node
NODE_ENV="production"
