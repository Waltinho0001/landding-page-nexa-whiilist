# ═══════════════════════════════════════════════════════════════════════════
# NEXA — Variáveis de Ambiente & Configurações de Segurança
# ═══════════════════════════════════════════════════════════════════════════
#
# ⚠️  SEGURANÇA CRÍTICA:
#   • NUNCA faça commit de .env com valores REAIS em produção
#   • Copie este arquivo para .env.local (Git: .env.local está no .gitignore)
#   • Use secrets manager (Vercel Secrets, AWS Secrets Manager, Vault)
#   • Revise regularmente permissões de acesso
#
# ═══════════════════════════════════════════════════════════════════════════

# ─── Banco de Dados PostgreSQL ────────────────────────────────────────────
# Obtenha em: https://neon.tech | https://supabase.com | https://render.com
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# 🔐 CRÍTICO: Sempre use SSL (sslmode=require)
DATABASE_URL="postgresql://user:password@db.example.com:5432/nexa_db?sslmode=require"

# ─── Resend (Envio de E-mail) ─────────────────────────────────────────────
# Obtenha em: https://resend.com/api-keys
# 🔐 CRÍTICO: Proteja esta chave como um segredo. Rotacione mensalmente.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"

# ─── E-mail Corporativo Destino ───────────────────────────────────────────
# Para notificações internas de novos registros
# Recomendado: usar email de grupo/lista de distribuição
CORPORATE_EMAIL="team@nexa.example.com"

# ─── Domínio do Frontend (CORS) ────────────────────────────────────────────
# Em produção: https://seu-dominio.com (HTTPS obrigatório)
# Em desenvolvimento: http://localhost:5173
# 🔐 CORS restrita a origens explícitas — sem '*'
DOMAIN="https://nexa.example.com"

# ─── Variáveis de Construção (Build-time) ─────────────────────────────────
# Nota: Prefixe com VITE_ para expor ao frontend (use apenas dados públicos!)
# Exemplo público (seguro):
VITE_APP_NAME="Nexa"
VITE_APP_VERSION="1.0.0"

# ─── Admin Secret (Módulo Administrativo) ──────────────────────────────────
# Token secreto para acesso às rotas /api/admin/*
# 🔐 CRÍTICO: Requisitos mínimos:
#   • Mínimo 32 caracteres (256 bits)
#   • Gerado com criptografia: openssl rand -hex 32
#   • Único por ambiente (dev ≠ prod)
#   • Nunca hardcoded em código, apenas em .env
#   • Rotacione quando houver vazamento suspeito
ADMIN_SECRET="mude-este-segreto-antes-de-producao-gerado-com-openssl-rand-hex-32"

# ─── Consentimento LGPD ────────────────────────────────────────────────────
# Versão da política de consentimento (mude se política foi atualizada)
# Rastreabilidade: permite auditoria de quando usuário consentiu
CONSENT_VERSION="1.0"

# ─── Ambiente de Execução ──────────────────────────────────────────────────
# Valores: development | production | staging
# 🔐 Impacta logs, tratamento de erros e segurança
NODE_ENV="production"

# ─── Logs & Observabilidade (Opcional) ─────────────────────────────────────
# Integração com serviços de logging (Sentry, Datadog, New Relic, etc.)
# SENTRY_DSN="https://your-sentry-key@sentry.io/project"
# DATADOG_API_KEY="your-datadog-api-key"

# ═══════════════════════════════════════════════════════════════════════════
# CHECKLIST DE SEGURANÇA (Antes de Deploy)
# ═══════════════════════════════════════════════════════════════════════════
# ✅ DATABASE_URL: SSL habilitado?
# ✅ RESEND_API_KEY: Valor real gerado e rotacionado?
# ✅ ADMIN_SECRET: >= 32 chars, gerado com openssl rand -hex 32?
# ✅ DOMAIN: HTTPS em produção?
# ✅ NODE_ENV: Definido como "production"?
# ✅ Nenhuma .env com valores reais foi commitada?
# ✅ Secrets configurados no provedor de deploy (Vercel Console)?
# ✅ Logs sensiveis foram removidos ou mascarados?
# ═══════════════════════════════════════════════════════════════════════════