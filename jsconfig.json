{
  "compilerOptions": {
    "checkJs": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "module": "ESNext",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*", "api/**/*"],
  "exclude": ["node_modules", "frontend/node_modules"]
}
