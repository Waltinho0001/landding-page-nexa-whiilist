{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "checkJs": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "module": "ESNext"
  },
  "include": ["frontend/src/**/*", "api/**/*", "src/**/*"],
  "exclude": ["node_modules", "dist"]
}
